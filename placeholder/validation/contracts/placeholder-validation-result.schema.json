{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlaceholderValidationResult",
  "type": "object",
  "required": ["issues"],
  "properties": {
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["placeholder", "severity", "message"],
        "properties": {
          "placeholder": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["Block", "High", "Medium", "Low", "Info"]
          },
          "message": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
